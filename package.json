{
  "name": "@pcreative/license-client",
  "version": "1.0.3",
  "description": "License verification client for pcreative.dev templates — RS256 JWT, offline verification, soft-kill state machine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
