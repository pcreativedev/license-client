    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node obfuscate.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "license",
    "drm",
    "jwt",
    "rs256",
    "pcreative",
    "template",
